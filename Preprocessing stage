Here's a bash script to automate filtering across folders: 

#!/bin/bash

# Base directory containing your folders
base_dir="/mnt/e/X401SC24100039-Z01-F001_02/01.RawData"

# Loop through all folders starting with "AA_"
for folder in "${base_dir}"/AA_*; do
    # Define paths for SAM, BAM, and output files
    sam_file="${folder}/output.sam"
    sorted_bam="${folder}/sorted_output.bam"
    cleaned_fq="${folder}/non_human_cleaned.fq"

    # Check if the SAM file exists
    if [[ -f "$sam_file" ]]; then
        echo "Processing folder: ${folder}"

        # Convert SAM to sorted BAM
        echo "Converting SAM to sorted BAM..."
        samtools view -bS "$sam_file" | samtools sort -o "$sorted_bam"

        # Index the sorted BAM file
        echo "Indexing sorted BAM file..."
        samtools index "$sorted_bam"

        # Extract unmapped reads (non-human sequences)
        echo "Extracting unmapped reads..."
        samtools fastq -f 12 -F 256 "$sorted_bam" > "$cleaned_fq"

        # Optionally clean up intermediate files
        echo "Cleaning up intermediate files..."
        rm -f "$sam_file" "${sorted_bam}.bai"

        echo "Completed processing for folder: ${folder}"
    else
        echo "No SAM file found in folder: ${folder}, skipping."
    fi
done

echo "All folders processed!"


